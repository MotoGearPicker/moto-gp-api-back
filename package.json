{
  "name": "moto-gear-picker-api",
  "version": "1.0.0",
  "description": "API for moto gear picker application",
  "main": "dist/main.js",
  "packageManager": "pnpm@10.31.0",
  "engines": {
    "node": "24.14.0",
    "pnpm": "10.31.0"
  },
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "nest start",
    "start:dev:local": "dotenv -e .env.local -- nest start --watch",
    "start:dev:prod": "dotenv -e .env.prod -- nest start --watch",
    "start:debug": "nest start --debug --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "prisma:generate:products": "prisma generate --config=prisma/products/prisma.config.ts",
    "prisma:generate:app": "prisma generate --config=prisma/app/prisma.config.ts",
    "prisma:generate": "pnpm prisma:generate:products && pnpm prisma:generate:app",
    "prisma:pull:products": "prisma db pull --config=prisma/products/prisma.config.ts",
    "prisma:pull:app": "prisma db pull --config=prisma/app/prisma.config.ts",
    "prisma:push:products": "prisma db push --config=prisma/products/prisma.config.ts",
    "prisma:push:app": "prisma db push --config=prisma/app/prisma.config.ts",
    "prisma:migrate:app": "prisma migrate dev --config=prisma/app/prisma.config.ts",
    "prisma:migrate:app:prod": "prisma migrate deploy --config=prisma/app/prisma.config.ts",
    "prisma:migrate:products": "prisma migrate dev --config=prisma/products/prisma.config.ts",
    "prisma:migrate:products:prod": "prisma migrate deploy --config=prisma/products/prisma.config.ts",
    "prisma:studio:products": "prisma studio --config=prisma/products/prisma.config.ts",
    "prisma:studio:app": "prisma studio --config=prisma/app/prisma.config.ts",
    "heroku-postbuild": "pnpm prisma:generate && pnpm build"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1030.0",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "11.1.18",
    "@nestjs/jwt": "^11.0.0",
    "@nestjs/mapped-types": "^2.0.0",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/schedule": "^6.1.3",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/throttler": "^6.5.0",
    "@prisma/adapter-pg": "^7.4.2",
    "@prisma/client": "^7.5.0",
    "@types/multer": "^2.1.0",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "dotenv": "^17.3.1",
    "iovalkey": "^0.3.3",
    "multer": "2.1.1",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "passport-local": "^1.0.0",
    "pg": "^8.20.0",
    "prisma": "^7.4.2",
    "reflect-metadata": "^0.1.13",
    "resend": "^6.11.0",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/bcrypt": "^6.0.0",
    "@types/express": "^4.17.17",
    "@types/jest": "^29.5.2",
    "@types/node": "^24.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/passport-local": "^1.0.38",
    "@types/pg": "^8.18.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "dotenv-cli": "^11.0.0",
    "eslint": "9.26.0",
    "jest": "^29.5.0",
    "source-map-support": "^0.5.21",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.3"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
