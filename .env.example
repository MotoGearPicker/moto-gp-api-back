# App
PORT=3000
APP_ENV=local
APP_URL=http://localhost:3000
CORS_URLS=http://localhost:5173
PUBLIC_API_KEY=change_me_use_a_long_random_secret

# Base de datos existente (products) — solo lectura/pull
PRODUCTS_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/postgres"

# Base de datos de la API (users, auth, etc.)
APP_DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/moto_gear_app"

# JWT Admin
JWT_ADMIN_ACCESS_SECRET=change_me_access
JWT_ADMIN_REFRESH_SECRET=change_me_refresh
JWT_ADMIN_RESET_SECRET=change_me_reset

# JWT Expiry (optional — defaults: 15m / 7d / 1h)
JWT_ADMIN_ACCESS_EXPIRES=15m
JWT_ADMIN_REFRESH_EXPIRES=7d
JWT_ADMIN_RESET_EXPIRES=1h

# Sentry (optional — leave empty to disable)
SENTRY_DSN=
